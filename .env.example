# =====================================================================
# OPSCONSOLE - Variabili d'ambiente (template)
# Copiare in `.env` e compilare. NON committare il file `.env` reale.
# =====================================================================

# --- Generale ---
NODE_ENV=production
OPS_DOMAIN=ops.bacolionlife.it
PORT=3100

# --- Auth ---
# Email autorizzata per il login (single-user). Magic link inviato solo qui.
ADMIN_EMAIL=domenico94allocca@gmail.com
# Segreto per firmare i token di sessione (>=64 chars, generare con: openssl rand -base64 64)
SESSION_SECRET=replace-me-with-a-64-char-random-string
# Issuer TOTP (visualizzato nell'app authenticator)
TOTP_ISSUER=BacoliOnLife OpsConsole
# TTL magic link in minuti
MAGIC_LINK_TTL_MIN=10
# Durata sessione (giorni)
SESSION_TTL_DAYS=7

# --- Email (Resend) ---
RESEND_API_KEY=re_xxx
EMAIL_FROM=ops@bacolionlife.it

# --- DB OpsConsole (privato del portale) ---
OPSCONSOLE_DB_URL=postgresql://opsconsole:CHANGE_ME@opsconsole-postgres:5432/opsconsole

# --- DB Marketplace (utente READ-ONLY dedicato) ---
MARKETPLACE_DB_URL_RO=postgresql://opsconsole_ro:CHANGE_ME@marketplace-postgres:5432/marketplace

# --- Docker socket proxy (Tecnativa) ---
DOCKER_SOCKET_PROXY_HOST=opsconsole-socketproxy
DOCKER_SOCKET_PROXY_PORT=2375

# --- GitHub ---
# PAT con scope: contents:read, metadata:read (fine-grained, repo specifico)
GITHUB_TOKEN=ghp_xxx
GITHUB_OWNER=domenico94allocca-ui
GITHUB_REPO=BacoliOnLife

# --- Marketplace target ---
MARKETPLACE_HEALTH_URL=https://bacolionlife.it/api/health
MARKETPLACE_DOMAIN=bacolionlife.it

# --- Backup ---
# Path (montato in sola lettura nel container) dove sono salvati i dump del marketplace
BACKUP_DIR=/backups
# Soglia di alert se l'ultimo backup è più vecchio di N ore
BACKUP_FRESHNESS_HOURS=26
